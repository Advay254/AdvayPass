# ─── Required ───────────────────────────────────────────────────────────────
# Your Render deployment URL (no trailing slash)
SITE_URL=https://your-app.onrender.com

# ─── Optional: Supabase PostgreSQL ──────────────────────────────────────────
# Find this in: Supabase Dashboard → Settings → Database → Connection pooling → Connection string
# Copy the "Transaction" mode URI (port 6543) and paste below.
# Tables are created automatically on first run — no SQL scripts needed.
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Optional: Custom Smartlink ─────────────────────────────────────────────
# If not set, falls back to the built-in default smartlink
SMARTLINK_URL=https://your-smartlink-here.com/xxxxx
