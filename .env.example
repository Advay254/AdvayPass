# ─── Required ────────────────────────────────────────────────────────────────
# Your deployment URL (no trailing slash)
SITE_URL=https://your-domain.com

# ─── Optional: Supabase PostgreSQL ───────────────────────────────────────────
# Supabase → Settings → Database → Connection pooling → Transaction URI (port 6543)
# Tables are created automatically on first run — no SQL needed.
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Optional: Custom Smartlink ──────────────────────────────────────────────
# Falls back to built-in default if not set
SMARTLINK_URL=https://your-smartlink-here.com/xxxxx
